{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "ESNext"],
    "types": ["node"],          // gives access to process, __dirname, etc.
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["tests/**/*.ts", "SimplerToday/**/*.ts", "pages/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
